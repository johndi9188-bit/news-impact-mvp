# OpenAI 兼容 API（密钥仅放在本机，勿提交仓库）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 可选：Finnhub 市场资讯（https://finnhub.io 注册）
FINNHUB_API_KEY=

# 可选：圣路易斯联储 FRED 宏观序列（https://fred.stlouisfed.org/docs/api/api_key.html）
FRED_API_KEY=

# 仅开发：Next allowedDevOrigins 额外主机名（逗号分隔）。
# 用 http://127.0.0.1:端口 或手机访问 http://局域网IP:端口 若一直刷新/HMR 403，可填 IPv4，如 192.168.1.23
NEXT_DEV_ALLOWED_ORIGINS=
